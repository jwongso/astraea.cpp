# astraea.cpp environment overrides for docker compose.
#
# Copy to .env and edit. Anything left commented uses the default from
# docker-compose.yml. Anything you set here overrides Config::from_env at
# container startup.

# ---------------------------------------------------------------------------
# LLM upstreams - the one piece docker-compose deliberately doesn't run
# ---------------------------------------------------------------------------
# Set these to point at your llama-server / vLLM / OpenAI-compatible endpoint.
# On Docker Desktop (mac/win) and Linux with the extra_hosts entry already
# in compose, host.docker.internal resolves to the host machine.
#
# LLM_BASE_URL=http://host.docker.internal:8080/v1
# EMBED_BASE_URL=http://host.docker.internal:8081/v1
# RERANK_BASE_URL=http://host.docker.internal:8081/v1
# LLM_MODEL=qwen3
# EMBED_MODEL=BAAI/bge-m3

# ---------------------------------------------------------------------------
# Coordination - in_process (default) or redis for multi-host
# ---------------------------------------------------------------------------
# COORDINATOR_BACKEND=in_process
# LLM_GLOBAL_CONCURRENCY=1
# LLM_ACQUIRE_TIMEOUT_S=90
# IP_MAX_CONCURRENCY=3

# ---------------------------------------------------------------------------
# Auth - set to require X-API-Key on every request
# ---------------------------------------------------------------------------
# PUBLIC_TOKEN=

# ---------------------------------------------------------------------------
# CORS - tighten this to your frontend origin in production
# ---------------------------------------------------------------------------
# ALLOWED_ORIGIN=*

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
# LOG_LEVEL=info   # trace | debug | info | warn | err | critical | off

# ---------------------------------------------------------------------------
# Ports - only change if you have a port collision on the host
# ---------------------------------------------------------------------------
# PORT=8010
# QDRANT_PORT=6333
