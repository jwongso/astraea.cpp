PROJECT_NAME           = "astraea.cpp"
PROJECT_BRIEF          = "C++23 multi-jurisdiction legal RAG server"
PROJECT_NUMBER         = ""

OUTPUT_DIRECTORY       = docs/doxygen

INPUT                  = include apps/nz_tenancy/main.cpp apps/building_consents/main.cpp
RECURSIVE              = YES

EXTRACT_ALL            = NO
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = YES
EXTRACT_ANON_NSPACES   = NO

GENERATE_HTML          = YES
GENERATE_LATEX         = NO
GENERATE_XML           = NO
GENERATE_MAN           = NO

HTML_OUTPUT            = html
HTML_EXTRA_STYLESHEET  =
HTML_COLORSTYLE        = LIGHT

# Use brief descriptions in the member list
BRIEF_MEMBER_DESC      = YES
REPEAT_BRIEF           = YES
ABBREVIATE_BRIEF       = "The \$name class" "The \$name widget" "The \$name file" \
                         is provides specifies contains represents

# Do not warn on missing docs for things we did not document intentionally
WARN_IF_UNDOCUMENTED   = NO
WARN_NO_PARAMDOC       = NO

# Source browsing
SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO
STRIP_CODE_COMMENTS    = YES

# Preprocessor - needed so #ifdef ASTRAEA_ENABLE_TIMING blocks are shown
ENABLE_PREPROCESSING   = YES
MACRO_EXPANSION        = YES
EXPAND_ONLY_PREDEF     = NO
PREDEFINED             = ASTRAEA_ENABLE_TIMING

# Dot/graphviz (disable to avoid requiring graphviz)
HAVE_DOT               = NO

# File patterns
FILE_PATTERNS          = *.hpp *.cpp

# Exclude detail internals from the top-level index (still documented)
EXCLUDE_PATTERNS       = */third_party/* */build*/*

# Strip the absolute path prefix from filenames in the output
STRIP_FROM_PATH        = /home/wdha/proj/priv/astraea.cpp

QUIET                  = YES
WARNINGS               = YES
